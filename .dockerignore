# Things to always skip — caches, git, editor cruft, secrets.
.git
.github
.gitignore
.gitattributes
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.env
.env.local
.env.production
.env.worktree
*.pem
*.key

# Node / Bun install artifacts (we do our own fresh install inside
# the image — never ship the host machine's node_modules).
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
.npm
.bun

# Build output from local runs.
build
dist
out
coverage
.next
*.bun-build
**/*.bun-build
*.tsbuildinfo

# mprocs + runtime state — these live in mounted volumes at
# runtime; shipping the host's copies into the image would shadow
# the volume mounts.
mprocs.log
server/data/accounts.json
server/data/dev-agent-identity.json
server/data/player-*
caches

# React client — the xRSPS server does not import from these
# subtrees (verified by tracing the server's import graph from
# server/src/index.ts). Excluding them keeps the image lean.
src/client
src/components
src/picogl
src/media
src/webgl
public

# `src/ui` is almost entirely client-side React code, but one
# server gamemode file (server/gamemodes/vanilla/modals/
# smithingBarModalHandler.ts) imports numeric font constants from
# src/ui/fonts.ts. Exclude the whole src/ui tree except that one
# file so the server can resolve the import without pulling in the
# rest of the client UI layer.
src/ui/**
!src/ui/fonts.ts

# Client build tooling — irrelevant to the server image.
craco.config.*
babel.config.*
postcss.config.*
tailwind.config.*

# Docs and long-form markdown (keep README + CLAUDE.md).
docs
*.md
!README.md
!CLAUDE.md

# Test / scratch files.
tmp
.tmp
coverage
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# The Dockerfile + compose + entrypoint live in this repo but
# don't need to be inside the image. `.dockerignore` rules apply
# to the build context, not to the COPY --from of the entrypoint
# (which is a separate, explicit COPY in the Dockerfile).
Dockerfile
docker-compose.yml
.dockerignore
