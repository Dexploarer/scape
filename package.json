{
  "name": "osrs-web-client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@foxglove/wasm-bz2": "^0.1.1",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.7.13",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@wasm-audio-decoders/ogg-vorbis": "^0.1.20",
    "bzip2": "^0.1.1",
    "denque": "^2.1.0",
    "fast-memoize": "^2.5.2",
    "file-saver": "^2.0.5",
    "gl-matrix": "^3.4.3",
    "java-random": "^0.4.0",
    "js-xxhash": "^2.0.0",
    "jszip": "^3.10.1",
    "leva": "^0.9.35",
    "pako": "^2.1.0",
    "picogl": "^0.17.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-modal": "^3.16.1",
    "react-router-dom": "^6.14.2",
    "react-scripts": "5.0.1",
    "react-select": "^5.7.4",
    "threads": "^1.7.0",
    "typescript": "^5.1.6",
    "usehooks-ts": "^2.9.1",
    "wasm-gzip": "^1.0.1",
    "web-vitals": "^2.1.0",
    "webfontloader": "^1.6.28",
    "ws": "^8.19.0",
    "xxhash-wasm": "^1.0.2"
  },
  "scripts": {
    "toolkit": "yarn --cwd toolkit dev",
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "lint": "prettier --write \"./**/*.{js,ts,jsx,tsx,css,md}\"",
    "prepare": "husky install",
    "download-caches": "node scripts/download-caches.js",
    "export-textures": "npx tsx scripts/cache/export-textures.ts",
    "export-height-map": "npx tsx scripts/cache/export-height-map.ts",
    "export-items": "npx tsx scripts/cache/export-items.ts osrs-232_2025-08-27",
    "export-map-images": "npx tsx scripts/cache/export-map-images.ts --force",
    "mcp:generate": "node -r ts-node/register/transpile-only mcp/npc-anims-categorized.ts",
    "mcp": "node -r ts-node/register/transpile-only mcp/mcp.ts",
    "mcp-test": "node -r ts-node/register/transpile-only mcp/tests/test.ts",
    "server:start": "npx tsx server/src/index.ts",
    "server:dev": "npx tsx watch server/src/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:build-collision": "npx tsx server/scripts/build-collision-cache.ts --include-models --force",
    "server:analyze-doors": "node -r ts-node/register/transpile-only server/scripts/analyze-door-cache.ts",
    "server:export-league-tasks": "npx tsx server/scripts/export-league-tasks.ts",
    "server:test": "node -r ts-node/register/transpile-only server/scripts/run-tests.ts",
    "server:test:movement": "npx tsx server/scripts/run-movement-tests.ts",
    "server:autosave-stress": "npx tsx server/scripts/autosave-stress.ts",
    "extract:projectiles": "node scripts/projectile-extract.js",
    "test:planes": "node -r ts-node/register/transpile-only tests/plane_resolver.test.ts",
    "test:dialog-option": "node -r ts-node/register/transpile-only tests/dialog_option.test.ts",
    "cs2-decompile": "npx tsx --max-old-space-size=8192 scripts/cache/decompile-cs2.ts",
    "cs2-test": "yarn ts-node --skip-project cs2-decompiler/test/test_structure.ts"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      "chrome >= 67",
      "edge >= 79",
      "firefox >= 68",
      "opera >= 54",
      "safari >= 14"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/gzip-js": "^0.3.3",
    "@types/pako": "^2.0.3",
    "@types/react-modal": "^3.16.0",
    "@types/webfontloader": "^1.6.35",
    "adm-zip": "^0.5.10",
    "husky": "^8.0.3",
    "json-minimizer-webpack-plugin": "^4.0.0",
    "lint-staged": "^13.2.3",
    "path": "^0.12.7",
    "prettier": "^3.0.0",
    "sharp": "^0.32.6",
    "threads-plugin": "^1.4.0",
    "ts-node": "^10.9.1",
    "ts-shader-loader": "^2.0.2"
  }
}
